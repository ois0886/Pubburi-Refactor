<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pubburi.pub.model.dao.StampDao">

    <!-- 스탬프 적립 -->
    <insert id="insert" parameterType="Stamp" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_stamp (user_id, order_id, quantity)
        VALUES (#{userId}, #{orderId}, #{quantity})
    </insert>

    <!-- 사용자별 스탬프 이력 조회 -->
    <select id="selectByUserId" parameterType="string" resultType="Stamp">
        SELECT * FROM t_stamp WHERE user_id = #{userId}
    </select>

</mapper>
